# Telegram Bot Token (obtido via @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# Supabase (PostgreSQL gerenciado)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_chave_anon_aqui

# Groq API (NLP via LLM + Whisper para transcricao de voz + Visao)
GROQ_API_KEY=sua_chave_groq_aqui

# CGM FreeStyle Libre (opcional - ative para monitoramento continuo)
CGM_ENABLED=false
CGM_SYNC_INTERVAL_MINUTES=5

# Limiares clinicos (opcionais - valores padrao ja definidos)
# HYPO_THRESHOLD=70
# HYPER_THRESHOLD=180
# SEVERE_HYPER_THRESHOLD=250
# URGENT_LOW_THRESHOLD=54
